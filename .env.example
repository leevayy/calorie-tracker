# Copy to `.env` at repo root (gitignored).
# `npm run deploy:static` runs: node --env-file=../.env … (Node 20.6+).
# For production static deploy, set VITE_API_BASE_URL so `npm run build` (via deploy:static) picks it up.
VITE_API_BASE_URL=

# Yandex Cloud (general API — e.g. other services)
YC_API_KEY=
YC_API_SECRET=

# Yandex Object Storage — static access key (used by deploy:static → AWS CLI)
YC_S3_API_KEY=
YC_S3_API_SECRET=

YC_S3_BUCKET=
YC_S3_ENDPOINT=https://storage.yandexcloud.net
YC_S3_REGION=ru-central1

# Optional: object prefix inside the bucket (no leading/trailing slashes).
# deploy:static uses `aws s3 sync` without --delete (never removes remote keys).
# YC_S3_PREFIX=

# Postgres — used by Docker Compose for the `db` service (substitution in docker-compose.yml).
# Must match DATABASE_URL in backend/.env (same user, password, database name).
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=

# Public API hostname for Caddy when using docker-compose.prod.yml (e.g. api.example.com)
# API_DOMAIN=

# Legacy aliases (optional): S3_BUCKET, S3_ENDPOINT, S3_PREFIX, AWS_REGION, AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY
