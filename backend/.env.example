# Production: set NODE_ENV=production, strong JWT_SECRET, and CORS_ALLOWED_ORIGINS
# to your real SPA origin(s). DATABASE_URL user/password/db must match docker-compose
# POSTGRES_USER / POSTGRES_PASSWORD / POSTGRES_DB (or your managed Postgres URL).
NODE_ENV=development
HOST=0.0.0.0
PORT=3000
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://semcaltrack-s3.website.yandexcloud.net
DATABASE_URL=postgres://calorie_user:calorie_pass@db:5432/calorie_tracker
JWT_SECRET=replace_with_at_least_32_random_bytes_in_production
ACCESS_TOKEN_TTL_SECONDS=3600
REFRESH_TOKEN_TTL_SECONDS=2592000
RATE_LIMIT_MAX_REQUESTS_PER_MINUTE=10
RATE_LIMIT_COOLDOWN_SECONDS=900
DAILY_TIP_K_ANONYMITY_MIN=5
PARSE_FOOD_CACHE_TTL_SECONDS=604800
PARSE_FOOD_CACHE_MAX_ENTRIES=500
YANDEX_AI_STUDIO_API_KEY=
YANDEX_FOLDER_ID=
YANDEX_AI_STUDIO_URL=https://llm.api.cloud.yandex.net/v1/chat/completions
YANDEX_AI_STUDIO_MODEL=gpt://<your_folder_id>/deepseek-v32/latest
# Slug for Qwen3 when user selects it in Settings (or full gpt:// URI)
YANDEX_AI_STUDIO_MODEL_QWEN3=qwen3-235b-a22b-fp8/latest
